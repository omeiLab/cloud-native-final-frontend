# API base URL for local dev. The frontend calls this backend directly.
VITE_API_BASE_URL=https://cets.alanh.uk/api/v1

# WebSocket can be left empty so the frontend derives it from the API base.
# VITE_WS_BASE_URL=

# Playwright E2E backend target
E2E_API_BASE_URL=https://cets.alanh.uk/api/v1
E2E_WS_BASE_URL=wss://cets.alanh.uk/ws
