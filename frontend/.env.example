# 同學後端（若已含 /api/v1 也可）
VITE_API_BASE_URL=https://cets.alanh.uk

# 省略時會自動由 VITE_API_BASE_URL 推導 ws/wss://.../ws
# VITE_WS_BASE_URL=wss://cets.alanh.uk/ws

# 預設身份（EMPLOYEE / ADMIN / VERIFIER；FAMILY 會套用 EMPLOYEE token）
VITE_DEFAULT_ROLE=EMPLOYEE

# 若後端手動抽籤路徑與前端預設不同，可設完整網址（可用 {sessionId}{eventId} 佔位）
# VITE_ADMIN_LOTTERY_POST_URL=https://cets.alanh.uk/api/v1/admin/sessions/{sessionId}/your-lottery-action
