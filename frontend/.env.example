# API 基底（開發時建議走 Vite proxy，避免 CORS）
VITE_API_BASE_URL=/api/v1

# WebSocket 可先留空，讓前端依 API base 自動推導
# VITE_WS_BASE_URL=

# 預設身份（EMPLOYEE / ADMIN / VERIFIER；FAMILY 會套用 EMPLOYEE token）
VITE_DEFAULT_ROLE=EMPLOYEE

# 若後端手動抽籤路徑與前端預設不同，可設完整網址
# 支援佔位符 {sessionId} / {eventId}
# VITE_ADMIN_LOTTERY_POST_URL=https://your-backend.example.com/api/v1/admin/sessions/{sessionId}/your-lottery-action
