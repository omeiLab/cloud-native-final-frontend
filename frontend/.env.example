# Copy this file to .env.local and fill values for your environment.
VITE_BASE_PATH=/
VITE_API_BASE_URL=

# Optional. If empty, the frontend derives /ws from VITE_API_BASE_URL.
VITE_WS_BASE_URL=

# Verifier scanner device id. Must match backend TICKET_VERIFY_DEVICE_ALLOWLIST.
VITE_VERIFIER_DEVICE_ID=scanner-A-01

# Playwright E2E backend target
E2E_API_BASE_URL=
E2E_WS_BASE_URL=
